      "rounded": true, "width": 170, "height": 56 },
    { "id": "paid",        "label": "paid",             "shape": "rectangle",
      "fill": "#86efac", "stroke": "#15803d", "fillStyle": "solid", "roughness": 0,
      "rounded": true, "width": 140, "height": 56 },
    { "id": "fulfillment", "label": "fulfillment",      "shape": "rectangle",
      "fill": "#86efac", "stroke": "#15803d", "fillStyle": "solid", "roughness": 0,
      "rounded": true, "width": 160, "height": 56 },
    { "id": "shipped",     "label": "shipped",          "shape": "rectangle",
