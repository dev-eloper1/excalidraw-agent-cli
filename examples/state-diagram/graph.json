    { "from": "delivered",   "to": "end",         "label": "",           "stroke": "#047857", "style": "solid", "width": 2 },

    { "from": "placed",      "to": "cancelled",   "label": "cancel",     "stroke": "#dc2626", "style": "dashed", "width": 2 },
